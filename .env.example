# API Keys (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Security (REQUIRED - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long

# Database
DATABASE_URL=sqlite:///./chatbot.db

# Storage
CHROMA_PERSIST_DIR=./chroma_data
UPLOAD_DIR=./uploads

# WhatsApp Cloud API (Fallback — bot-level credentials override these)
META_VERIFY_TOKEN=my-secret-verify-token
META_APP_SECRET=your-meta-app-secret-for-signature-verification

# Environment
ENV=development

# CORS (Production only - comma separated)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
